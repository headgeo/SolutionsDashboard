# ============================================
# Solutions Dashboard — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ------- Supabase -------
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------- Google Gemini (Embeddings) -------
# Powers: document & search embeddings for vector similarity search
# Get a free API key at: https://aistudio.google.com/app/apikey
# Model: text-embedding-004 (768 dimensions)
# Free tier: 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key

# ------- Anthropic Claude (AI Features) -------
# Powers: AI-generated answers on search (RAG), document auto-summarization
# Get your API key at: https://console.anthropic.com/settings/keys
# Note: This is separate from a Claude Max subscription — you need an API key.
# Pricing: pay-per-use (see https://www.anthropic.com/pricing)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ------- App -------
NEXT_PUBLIC_APP_URL=http://localhost:3000
