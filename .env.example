# ============================================
# Solutions Dashboard — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ------- Supabase -------
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------- Voyage AI (Embeddings) -------
# Voyage AI is Anthropic's recommended embedding provider.
# Sign up at: https://dash.voyageai.com/
# Create an API key at: https://dash.voyageai.com/api-keys
# Free tier: 200M tokens/month (more than enough for most use cases)
VOYAGE_API_KEY=your_voyage_api_key

# ------- Anthropic Claude (AI Features) -------
# Powers: AI-generated answers on search (RAG), document auto-summarization
# Get your API key at: https://console.anthropic.com/settings/keys
# Note: This is separate from a Claude Max subscription — you need an API key.
# Pricing: pay-per-use (see https://www.anthropic.com/pricing)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ------- App -------
NEXT_PUBLIC_APP_URL=http://localhost:3000
